# TestMailbox Configuration

# Domain for generated email addresses
DOMAIN=testmailbox.dev

# SMTP server port (non-privileged)
SMTP_PORT=2525

# REST API port
API_PORT=8501

# How long inboxes live before auto-deletion (minutes)
INBOX_TTL_MINUTES=60

# How often to purge expired inboxes (seconds)
CLEANUP_INTERVAL_SECONDS=300

# SQLite database path
DB_PATH=/data/testmailbox/mailbox.db
